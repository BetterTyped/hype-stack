# -----------------
# Config
# -----------------
NODE_ENV=test
FRONTEND_URL=http://localhost:4000
SELF_HOST_URL=http://localhost:3000

# -----------------
# Databases
# -----------------

# Postgres Database
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=ai_password
POSTGRES_DB=hype_stack_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# Valkey Cache
VALKEY_PASSWORD=valkey_password
VALKEY_URL=valkey://localhost:6380

# RustFS Object Storage (test container on port 9002)
RUSTFS_ENDPOINT=http://localhost:9002
RUSTFS_ACCESS_KEY=rustfstest
RUSTFS_SECRET_KEY=rustfstest

# -----------------
# External Services
# -----------------

# Sentry
SENTRY_DSN=https://examplePublicKey@1234.ingest.sentry.io/0

# Resend (fake value for tests -- Resend is mocked in unit tests)
RESEND_API_KEY=re_test_fake
RESEND_FROM_DOMAIN=fake_resend_domain.com
