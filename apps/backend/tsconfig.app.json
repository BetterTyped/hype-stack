{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["es2023"],
    "types": ["node"],
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "./exported",
    "composite": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@backend/*": ["./src/*"],
      "@prisma/client": ["./src/db/postgres/generated/client"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "./global.d.ts", "src/db/postgres/types/schema.prisma"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs",
    "src/testing/**/*.ts"
  ],
  "references": [
    {
      "path": "../../packages/enums/tsconfig.lib.json"
    }
  ]
}
