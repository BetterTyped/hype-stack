{
  "name": "@hype-stack/backend",
  "version": "0.0.1",
  "private": true,
  "main": "./exported/index.ts",
  "module": "./exported/index.ts",
  "types": "./exported/index.ts",
  "exports": {
    ".": {
      "types": "./exported/index.ts",
      "default": "./exported/index.ts"
    },
    "./enums": {
      "types": "./exported/enums.ts",
      "default": "./exported/enums.ts"
    },
    "./types": {
      "types": "./exported/types.ts",
      "default": "./exported/types.ts"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migration:create": "prisma migrate dev",
    "migration:latest": "prisma migrate deploy",
    "migration:down": "prisma migrate resolve --rolled-back",
    "migration:reset": "prisma migrate reset",
    "rebuild-db": "./scripts/rebuild-db.sh",
    "typecheck": "prisma generate && tsgo -p tsconfig.app.json --noEmit && tsgo -p tsconfig.spec.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:services": "docker compose -f docker-compose.test.yml up -d && sleep 10",
    "test:migrate": "DATABASE_URL=postgresql://ai_user:ai_password@localhost:5434/hype_stack_test?schema=public prisma migrate deploy",
    "test:generate": "DATABASE_URL=postgresql://ai_user:ai_password@localhost:5434/hype_stack_test?schema=public prisma generate",
    "test:setup": "npm run test:services && npm run test:migrate && npm run test:generate",
    "test:clean": "docker compose -f docker-compose.test.yml down -v"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@hono/node-server": "^2.0.0",
    "@hono/node-ws": "^1.3.0",
    "@hype-stack/enums": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@workos-inc/node": "^9.1.1",
    "dotenv": "^17.4.2",
    "dotenv-expand": "^13.0.0",
    "hono": "^4.12.15",
    "iovalkey": "^0.3.3",
    "kysely": "^0.28.16",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "prisma-kysely": "^3.1.0",
    "resend": "^6.12.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/multer": "^2.1.0",
    "@types/pg": "^8.20.0"
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/vite:build",
        "outputs": [
          "{options.outputPath}"
        ],
        "defaultConfiguration": "production",
        "options": {
          "outputPath": "apps/backend/dist",
          "outputFileName": "main.js"
        },
        "configurations": {
          "development": {
            "mode": "development"
          },
          "production": {
            "mode": "production"
          }
        }
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build",
          "build-deps"
        ],
        "options": {
          "buildTarget": "@hype-stack/backend:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "@hype-stack/backend:build:development"
          },
          "production": {
            "buildTarget": "@hype-stack/backend:build:production"
          }
        }
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  }
}
