{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "rootDir": "../..",
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node", "vitest", "@testing-library/jest-dom"],
    "jsx": "react-jsx",
    "strict": true,
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "lib": ["es2023", "dom"],
    "paths": {
      "@/assets/*": ["./assets/*"],
      "@/*": ["./src/*"],
      "@hype-stack/backend": ["../backend/exported/index.ts"],
      "@hype-stack/backend/*": ["../backend/exported/*"],
      "@backend/*": ["../backend/src/*"],
      "@prisma/client": ["../backend/src/db/postgres/generated/client"]
    }
  },
  "include": [
    "configs/vite.web.config.mts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "../backend/global.d.ts"
  ]
}
