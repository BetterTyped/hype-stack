{
  "compilerOptions": {
    "composite": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "strict": true,
    "jsx": "react-jsx",
    "lib": ["es2023", "dom"],
    "outDir": "dist",
    "rootDir": "../..",
    "paths": {
      "@/assets/*": ["./assets/*"],
      "@/*": ["./src/*"],
      "@hype-stack/backend": ["../backend/exported/index.ts"],
      "@hype-stack/backend/*": ["../backend/exported/*"],
      "@hype-stack/enums": ["../../packages/enums/dist/index.d.ts"],
      "@hype-stack/enums/*": ["../../packages/enums/dist/*"],
      "@backend/*": ["../backend/src/*"],
      "@prisma/client": ["../backend/src/db/postgres/generated/client"]
    }
  },
  "extends": "../../tsconfig.base.json"
}
