{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["es2023", "dom"],
    "types": ["node", "vite/client"],
    "rootDir": "../..",
    "strict": true,
    "composite": true,
    "resolveJsonModule": true,
    "noUnusedLocals": false,
    "paths": {
      "@/assets/*": ["./assets/*"],
      "@/*": ["./src/*"],
      "@hype-stack/backend": ["../backend/exported/index.ts"],
      "@hype-stack/backend/*": ["../backend/exported/*"],
      "@hype-stack/enums": ["../../packages/enums/src/index.ts"],
      "@hype-stack/enums/*": ["../../packages/enums/src/*"]
    }
  },
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "configs/vite.web.config.mts",
    "vite.config.mts",
    "vitest.config.mts"
  ],
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.json", "../backend/exported/**/*.ts", "../backend/global.d.ts"],
  "references": [
    {
      "path": "../../packages/enums/tsconfig.lib.json"
    },
    {
      "path": "../backend/tsconfig.app.json"
    }
  ]
}
