{
  "name": "@hype-stack/enums",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "format": "pnpm --dir ../.. exec oxfmt --write packages/enums",
    "typecheck": "tsgo --noEmit",
    "lint": "pnpm --dir ../.. exec oxlint --fix packages/enums",
    "generate": "pnpm exec tsgo -b tsconfig.lib.json"
  },
  "nx": {
    "targets": {
      "generate": {
        "executor": "nx:run-commands",
        "cache": false,
        "options": {
          "command": "pnpm run generate",
          "cwd": "packages/enums"
        },
        "outputs": [
          "{projectRoot}/dist"
        ]
      },
      "test": {
        "options": {
          "passWithNoTests": true
        }
      }
    }
  }
}
